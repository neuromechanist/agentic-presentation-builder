            "type": "text",
            "content": "### Traditional \"Save\"",
            "style": {
              "fontSize": "large",
              "fontWeight": "bold"
            },
            "position": {
              "area": "left"
            }
          },
          {
            "type": "bullets",
            "items": [
              "Overwrites previous version",
              "Only current state exists",
              "Can't undo major changes",
              "No explanation of changes",
              "Individual file focus"
            ],
            "bulletStyle": "disc",
            "style": {
              "fontSize": "medium"
            },
            "position": {
              "area": "left",
              "order": 1
            }
          },
          {
            "type": "text",
            "content": "### Git \"Commit\"",
            "style": {
              "fontSize": "large",
              "fontWeight": "bold",
              "color": "#059669"
            },
            "position": {
              "area": "right"
            }
          },
          {
            "type": "bullets",
            "items": [
              "Keeps all previous versions",
              "Complete project snapshots",
              "Can return to any point",
              "Explains what and why",
              "Entire project focus"
            ],
            "bulletStyle": "disc",
            "style": {
              "fontSize": "medium"
            },
            "position": {
              "area": "right",
              "order": 1
            }
          },
          {
            "type": "text",
            "content": "**New habit:** Instead of Ctrl+S, think \"What story does this change tell?\" and commit with a message",
