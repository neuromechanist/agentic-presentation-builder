            "type": "text",
            "content": "### The Four Stages:",
            "style": {
              "fontSize": "large",
              "fontWeight": "bold"
            },
            "position": {
              "area": "content",
              "order": 1
            }
          },
          {
            "type": "bullets",
            "items": [
              "**Working Directory:** Your current files (what you see)",
              "**Staging Area:** Changes ready to be committed",
              "**Repository:** Permanent history of changes",
              "**Remote Repository:** Shared version on GitHub"
            ],
            "bulletStyle": "disc",
            "style": {
              "fontSize": "medium"
            },
            "position": {
              "area": "content",
              "order": 2
            }
